{
    "name": "booking-react-components",
    "version": "0.1.0",
    "description": "Experimental React components for a future BookIT replacement",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/app.js",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "dev": "react-router dev"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "packageManager": "pnpm@10.28.0",
    "dependencies": {
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@react-router/dev": "^7.14.0",
        "@react-router/node": "^7.14.0",
        "@types/node": "^25.5.2",
        "@types/react": "latest",
        "@types/react-dom": "^19.2.3",
        "isbot": "^5.1.37",
        "oxfmt": "latest",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.19.0",
        "react-dom": "^19.2.4",
        "react-router": "^7.14.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.3",
        "vite-tsconfig-paths": "^6.1.1"
    }
}
