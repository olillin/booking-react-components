{
    "name": "booking-react-components",
    "version": "0.1.0",
    "description": "Experimental React components for a future BookIT replacement",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/app.js",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "packageManager": "pnpm@10.28.0",
    "dependencies": {
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.19.0",
        "typescript": "^6.0.2"
    }
}
