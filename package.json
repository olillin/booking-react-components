            "default": "./dist/index.js"
        }
    },
    "packageManager": "pnpm@10.28.0",
    "peerDependencies": {
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@types/react": "latest",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "glob": "^13.0.6",
        "oxfmt": "latest",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.19.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "^5.9.3",
        "vite": "^8.0.3",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-lib-inject-css": "^2.2.2",
        "vite-tsconfig-paths": "^6.1.1"
    }
