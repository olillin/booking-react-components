{
    "name": "booking-react-components",
    "version": "0.1.0",
    "description": "Experimental React components for a future BookIT replacement",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc && vite build",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
